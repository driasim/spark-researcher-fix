      "offer_type": [
        "teardown",
        "comparison_page",
        "template_pack",
        "benchmark_report",
        "roi_calculator"
      ],
      "orchestration_layer": [
        "n8n_core",
        "mautic_campaigns",
        "hybrid_agent_stack"
      ],
      "primary_channel": [
        "x",
        "linkedin",
        "seo",
        "email",
        "communities",
        "partner_ecosystem"
      ],
      "tool_stack": [
        "n8n+posthog+twenty",
        "mautic+chatwoot+formbricks",
        "hybrid+seo+crm"
      ]
    },
    "enabled": true,
    "field_patterns": {
      "conversion_surface": "^(typebot|chatwoot|microsite|calendar_router)$",
      "feedback_loop": "^(posthog_twenty|formbricks_chatwoot|full_flywheel)$",
      "motion_id": "^(founder_led_content|programmatic_seo|signal_based_outbound|community_embeds|partner_distribution)$",
      "offer_type": "^(teardown|comparison_page|template_pack|benchmark_report|roi_calculator)$",
