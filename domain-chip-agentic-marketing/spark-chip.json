      "primary_channel": "^(x|linkedin|seo|email|communities|partner_ecosystem)$",
      "tool_stack": "^[a-z0-9+,_-]{3,120}$"
    },
    "model": "generic",
    "open_mutation_fields": [
      "tool_stack"
    ],
    "prompt_hints": [
      "Prefer closed-loop systems that connect research, messaging, distribution, capture, CRM, and analytics.",
      "Do not propose content volume without a measurement and feedback loop.",
      "Prefer one strong motion-channel-offer system over fragmented multi-channel activity.",
