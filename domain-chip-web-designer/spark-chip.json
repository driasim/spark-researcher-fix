        "contact_qualification",
        "explore_then_convert"
      ],
      "design_direction": [
        "editorial_minimal",
        "expressive_brutalist",
        "premium_motion",
        "product_precision",
        "playful_3d"
      ],
      "interaction_model": [
        "restrained",
        "guided_motion",
        "immersive_scrollytelling",
        "micro_interaction_rich",
        "app_like"
      ],
      "narrative_model": [
        "problem_proof_product",
        "story_demo_socialproof",
        "portfolio_case_study",
        "collection_feature_grid",
        "dashboard_task_first"
