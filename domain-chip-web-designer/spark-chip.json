      "A design direction should feel current, compositional, and intentional before it is considered benchmark worthy.",
      "Only promote patterns that survive both inspiration review and UI/UX guardrails."
    ],
    "required_fields": [
      "site_type",
      "design_direction",
      "narrative_model"
    ],
    "web_search": true
  },
  "io_protocol": "spark-hook-io.v1",
  "schema_version": "spark-chip.v1",
  "version": "0.1.0"
