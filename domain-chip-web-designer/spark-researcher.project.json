{
  "candidate_trials": [
    {
      "candidate_id": "global-baseline",
      "candidate_summary": "Measure the unfocused baseline with no coherent design system.",
      "hypothesis": "The baseline should expose how weak generic web design advice is before domain-specific structure is applied.",
      "mutations": {}
    },
    {
      "candidate_id": "award-balanced-marketing",
      "candidate_summary": "Test a premium marketing site that balances motion, proof, and conversion clarity.",
      "hypothesis": "A premium but disciplined marketing pattern should beat the baseline without accessibility collapse.",
      "mutations": {
        "accessibility_mode": "motion_respectful",
        "conversion_strategy": "single_primary_cta",
        "design_direction": "premium_motion",
        "interaction_model": "guided_motion",
        "narrative_model": "problem_proof_product",
        "proof_surface": "product_demo",
        "site_type": "marketing_site"
      }
    },
    {
      "candidate_id": "dashboard-task-first",
      "candidate_summary": "Test a dashboard design that prioritizes hierarchy, task flow, and self-serve product proof.",
      "hypothesis": "A task-first dashboard direction should raise UX and conversion while maintaining strong craft.",
      "mutations": {
        "accessibility_mode": "keyboard_first",
        "conversion_strategy": "self_serve_demo",
        "design_direction": "product_precision",
        "interaction_model": "app_like",
        "narrative_model": "dashboard_task_first",
        "proof_surface": "product_demo",
        "site_type": "saas_dashboard"
      }
    }
  ],
  "chip": {
    "manifest": "spark-chip.json",
    "path": "."
  },
  "commands": {
    "research": {
      "args": [],
      "cwd": ".",
      "kind": "chip-evaluate",
      "log_name": "domain-chip-web-designer.log"
    }
  },
  "eval_goal": "maximize",
  "eval_metric": "web_design_score",
  "guardrails": {
    "blocked_command_fragments": [
      "shutdown",
      "format",
      "reg delete",
      "Remove-Item",
      "del /f",
      "rm -rf"
    ],
    "consecutive_discard_limit": 3,
    "max_loop_iterations": 8,
    "require_clean_git_for_self_edit": true,
    "require_human_approval_for_self_edit": true
  },
  "memory": {
    "backend": "local"
  },
  "metrics": {
    "accessibility_safety_score": {
      "kind": "float",
      "pattern": "^accessibility_safety_score:\\s+([0-9.]+)$"
    },
    "award_signal_score": {
      "kind": "float",
      "pattern": "^award_signal_score:\\s+([0-9.]+)$"
    },
    "conversion_clarity_score": {
      "kind": "float",
      "pattern": "^conversion_clarity_score:\\s+([0-9.]+)$"
    },
    "interaction_craft_score": {
      "kind": "float",
      "pattern": "^interaction_craft_score:\\s+([0-9.]+)$"
    },
    "ux_system_score": {
      "kind": "float",
      "pattern": "^ux_system_score:\\s+([0-9.]+)$"
    },
    "verdict_confidence": {
      "kind": "float",
      "pattern": "^verdict_confidence:\\s+([0-9.]+)$"
    },
    "web_design_score": {
      "kind": "float",
      "pattern": "^web_design_score:\\s+([0-9.]+)$"
    }
  },
  "mutable_parameters": [],
  "mutable_targets": [
    "src/domain_chip_web_designer",
    "docs",
    "README.md",
    "spark-chip.json",
    "spark-researcher.project.json",
    "pyproject.toml"
  ],
  "project_name": "domain-chip-web-designer",
  "project_root": ".",
  "self_edit": {
    "auto_push": false,
    "branch_prefix": "self-edit/",
    "command": [],
    "commit_message_template": "Apply self-edit proposal {proposal_id}",
    "git_mode": "manual",
    "main_branch": "main",
    "mutable_targets": [
      "src/domain_chip_web_designer",
      "docs",
      "README.md",
      "spark-chip.json",
      "spark-researcher.project.json",
      "pyproject.toml"
    ],
    "prompt_preamble": "Keep the chip small, benchmark-first, and honest about the difference between award craft, UX truth, and real-world validation."
  },
  "trainers": []
}
